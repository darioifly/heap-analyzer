{
  "name": "@heap-analyzer/electron",
  "private": true,
  "version": "0.1.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').mkdirSync('dist/database',{recursive:true});require('fs').copyFileSync('src/database/schema.sql','dist/database/schema.sql')\"",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.9.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
